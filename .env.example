# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# AI API Keys (Optional - for AI features)

# Google Gemini API Key (https://makersuite.google.com/app/apikey)
GOOGLE_API_KEY=your-google-api-key-here

# Alibaba Qwen API Key (https://dashscope.aliyun.com/)
QWEN_API_KEY=your-qwen-api-key-here

# Anthropic Claude API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your-openai-api-key-here

# Hugging Face API Key (https://huggingface.co/settings/tokens)
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Email Notifications (Optional - choose one)

# Option A: Resend (Recommended)
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM=Portfolio <onboarding@resend.dev>

# Option B: Gmail (App Password, not regular password)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# Notification recipient email (defaults to GMAIL_USER)
NOTIFICATION_EMAIL=you@yourdomain.com

# Site URL (optional, for production)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# AI Services API Keys
# Get free API keys from the links below

# ==================== GEMINI (Google) ====================
# Free tier available - no credit card needed initially
# Get key: https://aistudio.google.com/
GOOGLE_API_KEY=your-google-api-key

# ==================== CLAUDE (Anthropic) ====================
# Free credits available
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# ==================== OPENAI ====================
# Free trial credits
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ==================== HUGGING FACE ====================
# Free tier with rate limits
# Get token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-huggingface-api-key

# ==================== QWEN (Alibaba) ====================
# Free tier available
# Get key: https://dashscope.aliyun.com/
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
